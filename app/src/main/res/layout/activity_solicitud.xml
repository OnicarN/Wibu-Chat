<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/imagen_login">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="30dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center"
            android:background="@drawable/border_pantalla">

            <!-- Icono amigo -->
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ic_launcher_foreground"
                android:background="@drawable/border_pantalla"
                android:padding="8dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/solicitudTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Solicitud de amistad"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/solicitudSubtitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alguien quiere ser tu amigo"
                android:textSize="17sp"
                android:textAlignment="center"
                android:textColor="#555555"
                android:layout_marginBottom="36dp"/>

            <Button
                android:id="@+id/btnAceptar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✓  Aceptar"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnRechazar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✕  Rechazar"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>