<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A"
    android:fitsSystemWindows="true">

    <!-- Header colorido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/chat_header_gradient">

        <!-- Avatar con inicial -->
        <TextView
            android:id="@+id/txtAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/avatar_circle"
            android:text="A"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txtNombreChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="en línea"
                android:textColor="#AAFFAA"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Botón llamada de voz -->
        <ImageButton
            android:id="@+id/btnLlamadaVoz"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_call"
            android:background="@android:color/transparent"
            android:tint="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <!-- Botón videollamada -->
        <ImageButton
            android:id="@+id/btnVideollamada"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@android:color/transparent"
            android:tint="#FFFFFF"/>

    </LinearLayout>

    <!-- Lista de mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMensajes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Barra de entrada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#1A1A2E">

        <EditText
            android:id="@+id/inputMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Escribe un mensaje..."
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:background="@drawable/input_mensaje_bg"
            android:padding="12dp"
            android:maxLines="4"/>

        <ImageButton
            android:id="@+id/btnEnviar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/btn_enviar_bg"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>