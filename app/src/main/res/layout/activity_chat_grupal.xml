<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/chat_header_gradient">

        <ImageButton
            android:id="@+id/btnVolverGrupal"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="#"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/avatar_circle"/>

        <TextView
            android:id="@+id/txtNombreGrupo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Grupo"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMensajesGrupal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#1A1A2E">

        <EditText
            android:id="@+id/inputMensajeGrupal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Escribe un mensaje..."

            android:textColor="#FFFFFF"
            android:background="@drawable/input_mensaje_bg"
            android:padding="12dp"
            android:maxLines="4"/>

        <ImageButton
            android:id="@+id/btnEnviarGrupal"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/btn_enviar_bg"
            android:layout_marginStart="8dp"
            />
    </LinearLayout>

</LinearLayout>